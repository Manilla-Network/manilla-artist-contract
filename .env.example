# ── Supabase (client — build-time, exposed to browser) ───────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# ── Supabase (server — runtime, never exposed to browser) ────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Resend email delivery ─────────────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key
RESEND_FROM=Manilla Collective <exclusive@rald.cloud>

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated list of admin email addresses
ADMIN_EMAIL=ideamack@gmail.com
EMAIL_TEST_TOKEN=your-random-test-token

# ── Deployment ────────────────────────────────────────────────────────────────
# Used to build logo URL in outbound emails
PUBLIC_SITE_URL=https://manilla-contract.pages.dev
